{
  "manifest_version": 3,
  "name": "EnvGuard — by Kerr",
  "version": "1.0.0",
  "description": "Know your environment. Color-coded banner for PROD/STAGING/DEV on every page. Zero config, zero telemetry.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle",
    "all_frames": false
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
